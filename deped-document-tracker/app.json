{
  "expo": {
    "name": "DocTracker",
    "slug": "deped-document-tracker",
    "version": "1.0.0",
    "scheme": "deped-tracker",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/wow.png",
    "splash": {
      "image": "./assets/wow.png",
      "resizeMode": "contain",
      "backgroundColor": "#F0F4FF"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/wow.png",
        "backgroundColor": "#0038A8"
      },
      "package": "com.deped.documenttracker",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.deped.documenttracker",
      "supportsTablet": true,
      "icon": "./assets/wow.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow DepEd Tracker to use your camera to scan document QR codes."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/wow.png",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bfb449ae-b254-4e5e-aa6e-858fa64f8973"
      }
    }
  }
}