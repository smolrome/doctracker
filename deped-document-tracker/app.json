{
  "expo": {
    "name": "DepEd Document Tracker",
    "slug": "deped-document-tracker",
    "userInterfaceStyle": "automatic",
    "version": "1.0.0",
    "scheme": "deped-tracker",
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow DepEd Tracker to use your camera for QR scanning."
        }
      ]
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0038A8"
      },
      "package": "com.deped.documenttracker"
    },
    "ios": {
      "bundleIdentifier": "com.deped.documenttracker",
      "supportsTablet": true
    }
  }
}